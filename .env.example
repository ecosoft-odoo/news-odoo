# ============================================
# Odoo Daily News — copy to .env and fill in
# (this file is the public template; .env is gitignored)
# ============================================

# Required: Groq API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_replace_me

# Required: Discord incoming webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace_me

# Optional: GitHub PAT (raises rate limit 60 → 5000 req/hr). Empty = anonymous.
GITHUB_TOKEN=ghp_replace_me

# Optional: defaults for CLI/cron (override per-run with --repo/--branch flags)
GITHUB_REPO=odoo/odoo
GITHUB_BRANCH=18.0
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: custom prompt template (placeholders: {repo} {branch} {date} {count} {commits})
# Leave empty to use the built-in digest format.
CUSTOM_PROMPT=

# Optional: web app only
FLASK_SECRET_KEY=change-me-in-production
PORT=5000
